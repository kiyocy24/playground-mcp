# cp terraform.tfvars.example terraform.tfvars して編集する
project_id = "your-project-id"
region     = "asia-northeast1"

# イメージを明示指定する場合(省略時は Artifact Registry の <service_name>:latest)
# image = "asia-northeast1-docker.pkg.dev/your-project-id/playground-mcp/playground-mcp:v0.1.0"

# 実運用では false にして IAM 認証を使う
allow_unauthenticated = true
