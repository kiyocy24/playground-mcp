# cp terraform.tfvars.example terraform.tfvars して編集する
project_id = "your-project-id"
region     = "asia-northeast1"

# イメージを明示指定する場合(省略時は Artifact Registry の <service_name>:latest)
# image = "asia-northeast1-docker.pkg.dev/your-project-id/playground-mcp/playground-mcp:v0.1.0"

# サービスの呼び出しを許可するユーザー / サービスアカウント
invoker_members = [
  "user:you@example.com",
]

# true にすると誰でもアクセス可能になる(検証用)。通常は false のまま invoker_members で制御する
allow_unauthenticated = false
